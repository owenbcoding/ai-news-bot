DISCORD_TOKEN=your_discord_bot_token_here
# Discord text channel ID where news should be posted
CHANNEL_ID=123456789012345678
# Optional: server (guild) ID for instant slash command sync
GUILD_ID=123456789012345678
# Poll interval in minutes (180 = every 3 hours)
POLL_MINUTES=180
# Max articles to post per poll cycle
MAX_POSTS_PER_RUN=12
# Posting behavior
# BATCH_POST=1 posts one message per poll with multiple links
BATCH_POST=1
# If BATCH_POST=0, delay between individual messages
POST_DELAY_SECONDS=2
# Diversity: max items per source per poll
MAX_PER_SOURCE_PER_RUN=3
# Where to store dedupe state (inside container by default)
SEEN_PATH=seen.json

